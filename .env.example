# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key (console.anthropic.com) - powers the discovery + enrichment agents
ANTHROPIC_API_KEY=

# Shared secret required in the x-cron-secret header to trigger /api/discover and
# /api/enrich from a scheduler (Vercel Cron, n8n, etc). Generate any random string.
CRON_SECRET=
